# MongoDB configuration
MONGODB_URL=mongodb://localhost:27017

# Claude API configuration
CLAUDE_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=60000
# CLAUDE_TEMPERATURE=0.0  # Used for non-thinking models; ignored for claude-opus-4-7

# Gemini API configuration
GEMINI_API_KEY=AI-your-api-key-here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MAX_TOKENS=65536
GEMINI_THINKING_LEVEL=high  # Used for gemini-3.5-flash; ignored for other models
# GEMINI_TEMPERATURE=0.0  # Used for non-thinking models; ignored for gemini-3.5-flash

# Application settings
DEBUG=true
LOG_LEVEL=INFO

# AgentArena Backend Configuration
BACKEND_FINDINGS_ENDPOINT=http://localhost:8080/api/insert-findings
BACKEND_SUBMISSIONS_ENDPOINT=http://localhost:8080/api/submissions
BACKEND_TASK_REPOSITORY_ENDPOINT=http://localhost:8080/api/task-repository
BACKEND_API_KEY=some-secret-key

# Task settings
TASK_ID=TESTTASK